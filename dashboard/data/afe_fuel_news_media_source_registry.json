{
  "name": "AFE fuel-price news media source registry",
  "version": "2026-05-08-draft-news-first",
  "description": "Country-level media/news source registry for refreshing a fuel-price news JSON feed. Sources are prioritized for news coverage rather than only official regulator price notices. Official/regulator pages can still be added as validation sources.",
  "refresh_recommendation": {
    "frequency": "daily during oil-price shocks; weekly during stable periods",
    "preferred_method": "Use GDELT/Google Custom Search/Bing News API or a Databricks job to query the source domains and search terms, write fuel_news.json, and let the dashboard load that JSON.",
    "avoid": "Avoid scraping directly from the browser dashboard; keep API keys and crawling logic outside the HTML."
  },
  "default_keywords": [
    "fuel price",
    "petrol",
    "gasoline",
    "diesel",
    "kerosene",
    "LPG",
    "pump price",
    "fuel subsidy",
    "fuel shortage",
    "price hike",
    "price adjustment"
  ],
